{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phpVersion": "8.4"
    },
    "buildCommand": "composer install --no-dev --optimize-autoloader && php artisan key:generate && npm install && npm run build",
    "watchPatterns": [
      "**"
    ]
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE"
  }
}
